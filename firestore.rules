rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // pairs, configs, brokers — public data managed by admin dashboard (no auth)
    match /pairs/{doc}   { allow read, write: if true; }
    match /configs/{doc} { allow read, write: if true; }
    match /brokers/{doc} { allow read, write: if true; }

    // tv_cache — written by proxy server via Admin SDK (rules don't apply to Admin SDK,
    //            but keep open in case fallback is needed)
    match /tv_cache/{doc} { allow read, write: if true; }

    // users — app uses broker account IDs (no Firebase Auth), allow open access
    match /users/{userId} {
      allow read, write: if true;
    }

    // everything else — deny writes, allow reads
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
